PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/herostream
USE_MEMORY_DB=false
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=herostream-api
KAFKA_ENABLED=false

# Email (optional — reset links print to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HeroStream <noreply@herostream.app>
